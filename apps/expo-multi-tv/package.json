{
  "name": "@multi-tv/expo-multi-tv",
  "main": "node_modules/expo/AppEntry.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "EXPO_TV=1 expo start",
    "android": "EXPO_TV=1 expo run:android",
    "ios": "EXPO_TV=1 expo run:ios",
    "web": "expo start --web --port 8082",
    "dev:web": "expo start --web --port 8082",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "prebuild": "EXPO_TV=1 expo prebuild --clean",
    "clean": "rm -rf node_modules",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@bam.tech/lrud": "*",
    "@expo/metro-runtime": "~4.0.0",
